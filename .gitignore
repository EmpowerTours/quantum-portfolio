.venv/
__pycache__/
*.pyc
.env
.ipynb_checkpoints/

# Outputs: by default ignored, but track reproducibility artefacts explicitly.
outputs/*
!outputs/hardware_run.json
!outputs/backtest.json
!outputs/signed_orders.json
!outputs/p_optimal.png
!outputs/backtest_equity.png

# PQ keypair — never commit the secret key.
keys/pq.sec
# Public key can be regenerated by re-running run_pq_demo.py; not tracked.
keys/pq.pub
